{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:nextjs": {
      "cache": false,
      "persistent": true,
      "inputs": [".env", ".env.local"]
    },
    "dev:cron": {
      "cache": false,
      "persistent": true,
      "inputs": [".env", ".env.local"]
    },
    "build": {
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local"],
      "cache": true
    }
  }
}
